{
  "name": "@mcp-toollatch/cli",
  "version": "0.0.0",
  "type": "module",
  "license": "Apache-2.0",
  "description": "CLI for MCP ToolLatch.",
  "types": "./src/index.ts",
  "bin": {
    "toollatch": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@mcp-toollatch/audit": "workspace:*",
    "@mcp-toollatch/core": "workspace:*",
    "@mcp-toollatch/policy": "workspace:*",
    "@mcp-toollatch/proxy": "workspace:*",
    "@mcp-toollatch/scanner": "workspace:*",
    "commander": "^12.1.0"
  }
}
